<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sn.iage.isi.employeejavafx.controllers.AccueilController">

    <MenuBar styleClass="main-menu-bar" VBox.vgrow="NEVER">
        <menus>

            <Menu mnemonicParsing="false" text="Fichier">
                <items>
                    <MenuItem mnemonicParsing="false" onAction="#logout" text="Déconnexion" />
                    <MenuItem mnemonicParsing="false" onAction="#quitApp" text="Quitter" />
                </items>
            </Menu>
            <Menu mnemonicParsing="false" text="Gestion">

                      <items>
                    <MenuItem mnemonicParsing="false" onAction="#ressources" text="Ressources" />
                    <MenuItem mnemonicParsing="false" onAction="#materiels" text="Materiels" />
                    <MenuItem mnemonicParsing="false" onAction="#dashboard" text="Dashboard" />
                    <MenuItem mnemonicParsing="false" onAction="#factures" text="Factures" />

                      </items>
            </Menu>

            <Menu fx:id="userMenu" mnemonicParsing="false" text="Utilisateurs">
                <items>
                    <MenuItem mnemonicParsing="false" onAction="#utilisateurs" text="Gestion des utilisateurs" />
                </items>
            </Menu>
            <Menu mnemonicParsing="false" text="Profil">
                <items>
                    <MenuItem mnemonicParsing="false" onAction="#profile" text="Voir mon profil" />
                </items>
            </Menu>


        </menus>
    </MenuBar>
    <AnchorPane fx:id="contentPane" maxHeight="-1.0" maxWidth="-1.0" VBox.vgrow="ALWAYS" />

</VBox>
